  "keyFeatures": [
    "Monorepo architecture with Turborepo and Bun runtime",
    "End-to-end type safety with Hono RPC client",
    "Next.js 16 frontend with Shadcn UI components",
    "PostgreSQL database with Drizzle ORM",
    "Better Auth with social provider integrations",
    "PostHog analytics and feature flags",
    "Auto-generated API documentation with Scalar",
    "Production-ready deployment with Docker and Vercel",
    "Built-in blog and documentation with Fumadocs",
